VITE_CONVEX_URL=
# Optional: defaults from VITE_CONVEX_URL (.cloud → .site)
VITE_CONVEX_SITE_URL=
VITE_APP_URL=https://sol-speedrun-tracker.vercel.app/
VITE_WHOP_APP_ID=app_fzTPuAf6g5bs9a
# Optional fallback if not in URL path (/experiences/exp_xxx)
VITE_WHOP_EXPERIENCE_ID=
VITE_WHOP_MEMBERSHIP_URL=https://whop.com/@me/settings/memberships/

# Convex (set with npx convex env set …)
WHOP_API_KEY=
WHOP_APP_ID=
# Fallback when experience id is not in the iframe URL (from Whop experience settings)
WHOP_EXPERIENCE_ID=
# Optional: WHOP_ACCESS_PASS_ID= or WHOP_COMPANY_ID=
WHOP_ACCESS_BYPASS=

# RS256 JWT keys for Convex auth (generate once, see README)
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_PUBLIC_KEY=
