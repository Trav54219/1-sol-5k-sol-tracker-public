VITE_CONVEX_URL=
VITE_WORKOS_CLIENT_ID=
# Production: https://sol-speedrun-tracker.vercel.app
VITE_WORKOS_REDIRECT_URI=http://localhost:5173
VITE_WHOP_MEMBERSHIP_URL=https://whop.com/@me/settings/memberships/

# Set this in Convex with:
# npx convex env set WORKOS_CLIENT_ID client_...
WORKOS_CLIENT_ID=

# Whop API key from your Whop app (Dashboard → Apps → API Keys)
# npx convex env set WHOP_API_KEY whop_...
WHOP_API_KEY=

# Local development only — skips Whop checks when true
# npx convex env set WHOP_ACCESS_BYPASS true
WHOP_ACCESS_BYPASS=
