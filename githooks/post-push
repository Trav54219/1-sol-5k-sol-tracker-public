#!/bin/sh
# Enable in this repo: git config core.hooksPath githooks
# After a push updates origin/main, prefer local branch main when the worktree is clean.
while read -r local_ref local_sha remote_ref remote_sha; do
	case "$remote_ref" in
	*refs/heads/main)
		if git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null; then
			git checkout main 2>/dev/null || true
		fi
		;;
	esac
done
exit 0
